---
import Base from '../layouts/Base.astro';

const featured = [
  { href: '/photography/cameraless/atom-city', title: 'Atom City', year: '2019—2022', cls: 'ph-1' },
  { href: '/photography/cameraless/urantia', title: 'Urantia', year: '2015—2017', cls: 'ph-3' },
  { href: '/photography/abstract/time', title: 'Time', year: '2014—2016', cls: 'ph-5' },
  { href: '/painting/cant-remember', title: "Can't Remember What I Was Trying to Forget", year: '2019—2021', cls: 'ph-8' },
];
---

<Base
  title="Ajay Malghan"
  description="Ajay Malghan is an artist working in cameraless and chromaskedasic photography, abstract and documentary image-making, film, and painting. Based in Rockville, Maryland."
>
  <section class="home">
    <ul class="grid">
      {featured.map((f) => (
        <li class="grid__cell">
          <a href={f.href}>
            <div class={`tile ${f.cls}`}></div>
            <div class="grid__meta">
              <span class="grid__title">{f.title}</span>
              {f.year && <span class="grid__year">{f.year}</span>}
            </div>
          </a>
        </li>
      ))}
    </ul>
  </section>
</Base>

<style>
  .home { padding: clamp(2rem, 4vw, 4rem) var(--page-x) 4rem; }

  .grid {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: clamp(0.75rem, 1.5vw, 1.25rem);
  }

  .grid__cell a { display: block; }

  .tile {
    aspect-ratio: 4 / 5;
    background: var(--paper-rise);
    overflow: hidden;
    transition: opacity 0.4s ease;
  }

  .grid__cell a:hover .tile { opacity: 0.85; }

  .grid__meta {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-top: 10px;
    padding: 0 2px;
    gap: 8px;
  }

  .grid__title { font-family: var(--font-body); font-size: var(--t-2); color: var(--ink); flex: 1; }
  .grid__year { font-family: var(--font-body); font-size: var(--t-1); color: var(--ink-faint); letter-spacing: 0.04em; white-space: nowrap; }

  .ph-1 { background: linear-gradient(135deg, #d4c4a8, #9a8568); }
  .ph-2 { background: linear-gradient(135deg, #e8e2d4, #a89c8a 60%, #4a4238); }
  .ph-3 { background: radial-gradient(circle at 40% 30%, #d8d0c0, #8a8275); }
  .ph-4 { background: linear-gradient(180deg, #c4b8a8, #6a5a4a 60%, #2a2520); }
  .ph-5 { background: linear-gradient(0deg, #b0a8a0, #d4ccc4); }
  .ph-6 { background: linear-gradient(150deg, #5a5856, #8a8782 60%, #c0bdb8); }
  .ph-7 { background: radial-gradient(circle at 70% 60%, #6a5a4a, #2a2520); }
  .ph-8 { background: linear-gradient(135deg, #c8b8a8, #8a7868 60%, #4a3828); }

  @media (max-width: 980px) { .grid { grid-template-columns: repeat(3, 1fr); } }
  @media (max-width: 720px) { .grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 440px) { .grid { grid-template-columns: 1fr; } }
</style>
