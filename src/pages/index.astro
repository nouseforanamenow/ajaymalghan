---
import Base from '../layouts/Base.astro';

const featured = {
  href: '/photography/cameraless/urantia',
  title: 'Urantia',
  src: '/images/urantia/13.jpg',
};
---

<Base
  title="Ajay Malghan"
  description="Ajay Malghan is an artist working in cameraless and chromaskedasic photography, abstract and documentary image-making, film, and painting. Based in Rockville, Maryland."
>
  <section class="home">
    <a class="hero" href={featured.href} aria-label={featured.title}>
      <img class="tile" src={featured.src} alt={featured.title} />
    </a>
  </section>
</Base>

<style>
  .home {
    padding: clamp(1rem, 3vw, 2.5rem) var(--page-x);
    height: calc(100svh - 8rem);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hero {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 100%;
    max-width: 100%;
  }

  .tile {
    max-height: 100%;
    max-width: 100%;
    width: auto;
    height: auto;
    object-fit: contain;
    display: block;
    transition: opacity 0.4s ease;
  }

  .hero:hover .tile { opacity: 0.9; }
</style>
