---
import Base from '../../layouts/Base.astro';

const cats = [
  { href: '/photography/light', title: 'Light' },
  { href: '/photography/cameraless', title: 'Cameraless' },
  { href: '/photography/film', title: 'Film' },
  { href: '/photography/documentary', title: 'Documentary' },
];
---

<Base
  title="Photography"
  description="Photography by Ajay Malghan spanning cameraless and chromaskedasic prints, abstract studies of light, 35mm film, and long-form documentary projects."
>
  <section class="split">
    <h1 class="display split__h">Photography</h1>

    <div class="split__grid">
      {cats.map((c) => (
        <a href={c.href} class="split__card">
          <h2 class="display split__name">{c.title}</h2>
        </a>
      ))}
    </div>
  </section>
</Base>

<style>
  .split { max-width: 1200px; margin: 0 auto; padding: clamp(2.5rem, 5vw, 4rem) var(--page-x); }
  .split__h { font-size: var(--t-6); margin-bottom: 3rem; font-weight: 400; }
  .split__grid {
    display: grid; grid-template-columns: repeat(2, 1fr); gap: 2.5rem;
    border-top: 1px solid var(--rule); padding-top: 3rem;
  }
  .split__card { display: block; transition: opacity 0.2s ease; }
  .split__card:hover { opacity: 0.65; }
  .split__name { font-size: var(--t-5); margin-bottom: 0.5rem; font-weight: 400; }
  .split__desc { color: var(--ink-dim); font-size: var(--t-3); max-width: 36ch; }
  @media (max-width: 720px) { .split__grid { grid-template-columns: 1fr; gap: 1.75rem; } }
</style>
