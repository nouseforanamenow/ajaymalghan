---
import { getCollection } from 'astro:content';
import Base from '../../../layouts/Base.astro';

const series = (await getCollection('light', ({ data }) => !data.draft))
  .sort((a, b) => {
    const ao = a.data.order ?? 999;
    const bo = b.data.order ?? 999;
    if (ao !== bo) return ao - bo;
    return (b.data.year || '').localeCompare(a.data.year || '');
  });
---

<Base
  title="Light"
  description="Long-exposure studies of light by Ajay Malghan — abstract photographs that draw shape and color from movement, reflection, and time-based exposure."
>
  <section class="idx">
    <h1 class="display idx__h">Light</h1>

    <ul class="idx__list">
      {series.map((s) => (
        <li class="idx__row">
          <a href={`/photography/light/${s.slug}`}>
            <span class="idx__thumb"><img src={s.data.cover} alt="" loading="lazy" decoding="async" onerror="this.remove();" /></span>
            <h2 class="display idx__name">{s.data.title}</h2>
            {s.data.year && <span class="idx__year">{s.data.year}</span>}
          </a>
        </li>
      ))}
    </ul>
  </section>
</Base>

<style>
  .idx { max-width: 1100px; margin: 0 auto; padding: clamp(2.5rem, 5vw, 4rem) var(--page-x); }
  .idx__h { font-size: var(--t-6); margin-bottom: 3rem; font-weight: 400; }
  .idx__list { list-style: none; border-top: 1px solid var(--rule); }
  .idx__row { border-bottom: 1px solid var(--rule); }
  .idx__row a {
    display: flex; align-items: center; gap: 1.25rem;
    padding: 1.25rem 0; transition: padding 0.25s ease;
  }
  .idx__row a:hover { padding-left: 0.5rem; }
  .idx__thumb {
    flex: 0 0 60px; width: 60px; height: 75px; display: block;
    background: var(--paper-rise); overflow: hidden;
  }
  .idx__thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .idx__name { flex: 1; font-size: var(--t-5); font-weight: 400; }
  .idx__year { font-family: var(--font-body); font-size: var(--t-2); color: var(--ink-faint); }
</style>
