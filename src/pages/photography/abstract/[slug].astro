---
import { getCollection } from 'astro:content';
import Base from '../../../layouts/Base.astro';
import Slideshow from '../../../components/Slideshow.astro';
import VideoPlate from '../../../components/VideoPlate.astro';
import { seriesSchema } from '../../../lib/schema.js';

export async function getStaticPaths() {
  const entries = await getCollection('abstract', ({ data }) => !data.draft);
  return entries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const data = entry.data;
const jsonLd = seriesSchema({ ...data, slug: entry.slug, category: 'abstract' });
---

<Base
  title={data.title}
  description={data.description}
  keywords={data.keywords}
  ogImage={data.cover}
  schema={jsonLd}
  pieceTitle={data.title}
>
  <article class="series">
    <div class="series__prose"><Content /></div>

    {data.videos && data.videos.length > 0 && (
      <div class="series__videos">
        {data.videos.map((video, i) => (
          <VideoPlate video={video} index={i} />
        ))}
      </div>
    )}

    <div class="series__slideshow">
      <Slideshow images={data.images} />
    </div>
    <nav class="series__after">
      <a href="/photography/abstract">← All abstract work</a>
    </nav>
  </article>
</Base>

<style>
  .series {
    max-width: 1200px; margin: 0 auto; padding: 0 var(--page-x);
    height: calc(100svh - 8rem);
    display: flex; flex-direction: column;
  }
  .series__prose :global(p) {
    font-family: var(--font-body); font-size: var(--t-2); line-height: 1.55;
    color: var(--ink-dim); margin-bottom: 0.4em; max-width: 62ch;
  }
  .series__prose :global(p:empty) { display: none; }
  .series__prose :global(a) { border-bottom: 1px solid var(--rule); }
  .series__slideshow { flex: 1; min-height: 0; }
  .series__videos {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: clamp(1.5rem, 3vw, 2.5rem);
    justify-items: center;
    margin-bottom: 0.75rem;
  }
  .series__after { display: none; }
</style>
