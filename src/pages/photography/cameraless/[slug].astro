---
import { getCollection } from 'astro:content';
import Base from '../../../layouts/Base.astro';
import Slideshow from '../../../components/Slideshow.astro';
import { seriesSchema, visualArtworkSchema } from '../../../lib/schema.js';

export async function getStaticPaths() {
  const entries = await getCollection('cameraless', ({ data }) => !data.draft);
  return entries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const data = { ...entry.data, category: 'cameraless' };
const schemas = [
  visualArtworkSchema(data, entry.slug),
  seriesSchema({ ...data, slug: entry.slug }),
];
---

<Base
  title={data.title}
  description={data.description}
  ogImage={data.cover}
  schema={schemas}
  pieceTitle={data.title}
>
  <article class="series">
    <div class="series__prose"><Content /></div>
    <div class="series__slideshow">
      <Slideshow images={data.images} />
    </div>
    <nav class="series__after">
      <a href="/photography/cameraless">← All cameraless work</a>
    </nav>
  </article>
</Base>

<style>
  .series {
    max-width: 1200px; margin: 0 auto; padding: 0 var(--page-x);
    height: calc(100svh - 8rem);
    display: flex; flex-direction: column;
  }
  .series__prose :global(p) {
    font-family: var(--font-body); font-size: var(--t-2); line-height: 1.55;
    color: var(--ink-dim); margin-bottom: 0.4em; max-width: 62ch;
  }
  .series__prose :global(p:empty) { display: none; }
  .series__prose :global(a) { border-bottom: 1px solid var(--rule); }
  .series__slideshow { flex: 1; min-height: 0; }
  .series__after { display: none; }
</style>
