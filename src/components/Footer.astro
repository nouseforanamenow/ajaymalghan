---
const { pieceTitle = '' } = Astro.props;
---

<footer class="foot">
  <div class="foot__zone foot__zone--left">
    <a href="/" class="foot__mark" aria-label="Ajay Malghan home">
      <svg viewBox="0 0 24 24" width="22" height="22" aria-hidden="true">
        <path d="M2 21 L12 3 L22 21 Z" fill="none" stroke="currentColor" stroke-width="1.4" />
        <path d="M7.5 14.5 L16.5 14.5" stroke="currentColor" stroke-width="1.4" />
      </svg>
    </a>
    <form class="foot__subscribe" action="https://ajaymalghan.substack.com/subscribe" method="get" target="_blank" rel="noopener">
      <input type="email" name="email" placeholder="Email" required class="foot__input" />
      <button type="submit" class="foot__submit">Sign Up</button>
    </form>
    <a href="https://www.instagram.com/ajaymalghan/" target="_blank" rel="noopener" class="foot__ig" aria-label="Instagram">
      <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
        <rect x="3" y="3" width="18" height="18" rx="4" fill="none" stroke="currentColor" stroke-width="1.4" />
        <circle cx="12" cy="12" r="4" fill="none" stroke="currentColor" stroke-width="1.4" />
        <circle cx="17.5" cy="6.5" r="1" fill="currentColor" />
      </svg>
    </a>
  </div>

  <div class="foot__zone foot__zone--center">
    <button class="foot__ctrl" data-slideshow-prev aria-label="Previous image">
      <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true"><path d="M15 4 L7 12 L15 20" fill="none" stroke="currentColor" stroke-width="1.4" /></svg>
    </button>
    <button class="foot__ctrl foot__ctrl--grid" data-slideshow-grid aria-label="View grid">
      <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
        <circle cx="6" cy="6" r="1.2" fill="currentColor"/>
        <circle cx="12" cy="6" r="1.2" fill="currentColor"/>
        <circle cx="18" cy="6" r="1.2" fill="currentColor"/>
        <circle cx="6" cy="12" r="1.2" fill="currentColor"/>
        <circle cx="12" cy="12" r="1.2" fill="currentColor"/>
        <circle cx="18" cy="12" r="1.2" fill="currentColor"/>
        <circle cx="6" cy="18" r="1.2" fill="currentColor"/>
        <circle cx="12" cy="18" r="1.2" fill="currentColor"/>
        <circle cx="18" cy="18" r="1.2" fill="currentColor"/>
      </svg>
    </button>
    <button class="foot__ctrl" data-slideshow-next aria-label="Next image">
      <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true"><path d="M9 4 L17 12 L9 20" fill="none" stroke="currentColor" stroke-width="1.4" /></svg>
    </button>
  </div>

  <div class="foot__zone foot__zone--right">
    <span class="foot__title">{pieceTitle}</span>
  </div>
</footer>

<style>
  .foot {
    position: fixed;
    left: 0; right: 0; bottom: 0;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 1rem;
    padding: 0.85rem var(--page-x);
    background: var(--paper);
    border-top: 1px solid var(--rule);
    z-index: 50;
    min-height: 3.25rem;
  }

  .foot__zone { display: flex; align-items: center; gap: 0.85rem; }
  .foot__zone--left { justify-content: flex-start; }
  .foot__zone--center { justify-content: center; }
  .foot__zone--right { justify-content: flex-end; }

  .foot__mark {
    display: inline-flex;
    color: var(--ink);
    line-height: 0;
    transition: opacity 0.2s ease;
  }
  .foot__mark:hover { opacity: 0.6; }

  .foot__subscribe {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }
  .foot__input {
    font-family: var(--font-body);
    font-size: var(--t-1);
    color: var(--ink);
    background: transparent;
    border: 0;
    border-bottom: 1px solid var(--rule);
    padding: 0.25rem 0.25rem 0.3rem;
    width: 7rem;
    outline: none;
    transition: border-color 0.2s ease;
  }
  .foot__input::placeholder { color: var(--ink-faint); }
  .foot__input:focus { border-bottom-color: var(--ink); }

  .foot__submit {
    font-family: var(--font-body);
    font-size: var(--t-1);
    color: var(--ink-dim);
    background: transparent;
    border: 0;
    cursor: pointer;
    padding: 0.25rem 0.5rem;
    transition: color 0.2s ease;
  }
  .foot__submit:hover { color: var(--ink); }

  .foot__ig {
    display: inline-flex;
    color: var(--ink-dim);
    line-height: 0;
    transition: color 0.2s ease;
  }
  .foot__ig:hover { color: var(--ink); }

  .foot__ctrl {
    background: transparent;
    border: 0;
    cursor: pointer;
    padding: 0.4rem 0.55rem;
    color: var(--ink-dim);
    display: inline-flex;
    transition: color 0.2s ease;
    line-height: 0;
  }
  .foot__ctrl:hover { color: var(--ink); }

  .foot__title {
    font-family: var(--font-body);
    font-size: var(--t-1);
    color: var(--ink-dim);
    text-align: right;
    letter-spacing: 0.02em;
  }

  @media (max-width: 720px) {
    .foot { grid-template-columns: 1fr; gap: 0.4rem; padding: 0.6rem var(--page-x); }
    .foot__zone--right { display: none; }
    .foot__input { width: 5.5rem; }
  }
</style>
