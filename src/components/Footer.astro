---
const year = new Date().getFullYear();
---

<footer class="foot">
  <div class="foot__row">
    <span class="foot__name">Ajay Malghan</span>
    <span class="foot__meta">© {year}</span>
  </div>
</footer>

<style>
  .foot {
    padding: 3rem var(--page-x) 2rem;
    border-top: 1px solid var(--rule);
    margin-top: 5rem;
  }
  .foot__row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .foot__name { font-family: var(--font-body); font-size: var(--t-2); color: var(--ink); }
  .foot__meta { font-family: var(--font-body); font-size: var(--t-1); color: var(--ink-faint); }
</style>
