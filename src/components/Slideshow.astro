---
import { gradientFor } from '../lib/gradients.js';
const { images = [], videos = [] } = Astro.props;
const slides = [
  ...videos.map((v) => ({ kind: 'video', data: v })),
  ...images.map((i) => ({ kind: 'image', data: i })),
];
const total = slides.length;
const hasCaptions = images.some((i) => i.caption);
---

<div class={`slideshow ${hasCaptions ? 'slideshow--captioned' : ''}`} data-slideshow data-total={total}>
  <div class="slideshow__viewport">
    {slides.map((slide, i) => {
      const isActive = i === 0;
      if (slide.kind === 'video') {
        const v = slide.data;
        const ratio = v.aspectRatio || (v.vimeo ? '16/9' : '9/16');
        const src = v.vimeo
          ? `https://player.vimeo.com/video/${v.vimeo}?title=0&byline=0&portrait=0&badge=0&autopause=0`
          : null;
        return (
          <div
            class={`slide slide--video ${isActive ? 'slide--active' : ''}`}
            data-index={i}
            data-kind="video"
          >
            <div class="slide__video-frame" style={`aspect-ratio: ${ratio};`}>
              {src ? (
                <iframe
                  src={src}
                  title={v.title || v.alt}
                  frameborder="0"
                  allow="autoplay; fullscreen; picture-in-picture; clipboard-write; encrypted-media; web-share"
                  referrerpolicy="strict-origin-when-cross-origin"
                  loading={i < 1 ? 'eager' : 'lazy'}
                ></iframe>
              ) : (
                <video
                  src={v.src}
                  poster={v.poster}
                  controls
                  playsinline
                  preload={i < 1 ? 'metadata' : 'none'}
                  aria-label={v.alt}
                ></video>
              )}
            </div>
          </div>
        );
      }
      const img = slide.data;
      return (
        <div
          class={`slide ${isActive ? 'slide--active' : ''}`}
          data-index={i}
          data-kind="image"
          style={`--ph-gradient: ${gradientFor((img.src || '') + i)}`}
        >
          <img
            src={img.src}
            alt={img.alt || ''}
            loading={i < 2 ? 'eager' : 'lazy'}
            decoding="async"
            onerror="this.closest('.slide').classList.add('slide--missing'); this.remove();"
          />
          {img.caption && (
            <div class="slide__caption">
              {img.title && <span class="slide__caption-title">{img.title}</span>}
              <span class="slide__caption-body">{img.caption}</span>
            </div>
          )}
        </div>
      );
    })}
  </div>

  {total > 1 && (
    <>
      <button class="slideshow__zone slideshow__zone--prev" data-slideshow-prev aria-label="Previous" tabindex="-1"></button>
      <button class="slideshow__zone slideshow__zone--next" data-slideshow-next aria-label="Next" tabindex="-1"></button>
      <div class="slideshow__counter" aria-live="polite">
        <span class="js-current">1</span><span class="slideshow__sep">/</span><span>{total}</span>
      </div>
    </>
  )}
</div>

<style>
  .slideshow {
    position: relative;
    width: 100%;
    /* Fills the flex container — parent reserves space between nav, intro, and footer. */
    height: 100%;
    min-height: 320px;
    user-select: none;
  }

  .slideshow__viewport {
    position: relative;
    width: 100%;
    height: 100%;
  }

  .slide {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.4s ease;
    pointer-events: none;
  }

  .slide--active {
    opacity: 1;
    pointer-events: auto;
  }

  .slide img {
    /* additional 10% shrink so the frame sits clearly within the viewport */
    max-width: 90%;
    max-height: 90%;
    width: auto;
    height: auto;
    object-fit: contain;
    display: block;
  }

  /* When captions are present, render image on the left and caption on the right */
  .slideshow--captioned .slide {
    flex-direction: row;
    align-items: center;
    justify-content: center;
    gap: clamp(1.25rem, 3vw, 2.5rem);
    padding: 0 clamp(1rem, 3vw, 2rem);
  }
  .slideshow--captioned .slide img {
    max-height: 92%;
    max-width: min(60%, 720px);
    flex: 0 1 auto;
  }
  .slide__caption {
    flex: 0 1 36ch;
    max-width: 36ch;
    text-align: left;
    font-family: var(--font-body);
    font-size: var(--t-2);
    color: var(--ink-dim);
    line-height: 1.6;
    display: grid;
    gap: 0.65rem;
    pointer-events: none;
  }
  .slide__caption-title {
    font-size: var(--t-3);
    color: var(--ink);
    letter-spacing: 0.01em;
    font-weight: 500;
  }
  .slide__caption-body { color: var(--ink-dim); }

  @media (max-width: 760px) {
    .slideshow--captioned .slide {
      flex-direction: column;
      gap: 1rem;
      padding: 0 1rem;
    }
    .slideshow--captioned .slide img { max-width: 100%; max-height: 65%; }
    .slide__caption { max-width: 100%; text-align: center; }
  }

  .slide__video-frame {
    /* fill the slide height, computing width from aspect-ratio
       (set inline on the element); clamp width if it would overflow */
    height: 100%;
    width: auto;
    max-width: 100%;
    background: var(--paper-rise);
    position: relative;
    overflow: hidden;
  }
  .slide__video-frame iframe,
  .slide__video-frame video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
    display: block;
  }

  .slide--missing {
    background: var(--ph-gradient, var(--paper-rise));
    aspect-ratio: 4 / 5;
    max-width: 60%;
    max-height: 90%;
    margin: auto;
  }

  .slideshow__counter {
    position: absolute;
    bottom: 0.5rem;
    left: 50%;
    transform: translateX(-50%);
    font-family: var(--font-body);
    font-size: var(--t-1);
    color: var(--ink-faint);
    letter-spacing: 0.08em;
    pointer-events: none;
  }
  .slideshow__sep { padding: 0 0.3rem; color: var(--rule); }

  .slideshow__zone {
    position: absolute;
    top: 0; bottom: 0;
    width: 50%;
    background: transparent;
    border: 0;
    padding: 0;
    z-index: 3;
  }
  .slideshow__zone--prev {
    left: 0;
    cursor: url('/cursors/arrow-left.svg') 16 16, w-resize;
  }
  .slideshow__zone--next {
    right: 0;
    cursor: url('/cursors/arrow-right.svg') 16 16, e-resize;
  }
  .slideshow__zone:focus { outline: none; }

  /* When a video slide is active, drop the click zones entirely so the
     Vimeo player's play button and scrubber are clickable. Navigation
     still works via the footer arrows, keyboard, and touch swipe. */
  .slideshow--video .slideshow__zone {
    pointer-events: none;
  }

</style>

<script>
  document.querySelectorAll('.slideshow').forEach((s) => {
    const slides = s.querySelectorAll('.slide');
    if (!slides.length) return;
    const counter = s.querySelector('.js-current');
    let i = 0;

    const pauseSlideMedia = (slide) => {
      slide.querySelectorAll('iframe').forEach((f) => {
        try {
          f.contentWindow?.postMessage(JSON.stringify({ method: 'pause' }), '*');
        } catch {}
      });
      slide.querySelectorAll('video').forEach((v) => { try { v.pause(); } catch {} });
    };

    const syncMode = () => {
      const kind = slides[i].dataset.kind;
      s.classList.toggle('slideshow--video', kind === 'video');
    };

    const go = (n) => {
      const prev = slides[i];
      prev.classList.remove('slide--active');
      pauseSlideMedia(prev);
      i = (n + slides.length) % slides.length;
      slides[i].classList.add('slide--active');
      if (counter) counter.textContent = String(i + 1);
      syncMode();
    };

    syncMode();

    // Controls live in the footer (data-slideshow-prev / -next). Hook at document level.
    document.querySelectorAll('[data-slideshow-prev]').forEach((btn) =>
      btn.addEventListener('click', () => go(i - 1))
    );
    document.querySelectorAll('[data-slideshow-next]').forEach((btn) =>
      btn.addEventListener('click', () => go(i + 1))
    );

    // Grid button: scroll back to series index based on URL.
    document.querySelectorAll('[data-slideshow-grid]').forEach((btn) =>
      btn.addEventListener('click', () => {
        const parts = location.pathname.split('/').filter(Boolean);
        if (parts.length >= 2) {
          // .../film/hk-alleys -> .../film
          parts.pop();
          location.href = '/' + parts.join('/');
        }
      })
    );

    document.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowLeft') go(i - 1);
      else if (e.key === 'ArrowRight') go(i + 1);
    });

    // Touch swipe on the slideshow itself
    let touchX = null;
    s.addEventListener('touchstart', (e) => { touchX = e.touches[0].clientX; }, { passive: true });
    s.addEventListener('touchend', (e) => {
      if (touchX == null) return;
      const dx = e.changedTouches[0].clientX - touchX;
      if (Math.abs(dx) > 40) go(dx < 0 ? i + 1 : i - 1);
      touchX = null;
    }, { passive: true });
  });
</script>
