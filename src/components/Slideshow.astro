---
import { gradientFor } from '../lib/gradients.js';
const { images } = Astro.props;
---

<div class="slideshow" data-total={images.length}>
  <div class="slideshow__viewport">
    {images.map((img, i) => (
      <div
        class={`slide ${i === 0 ? 'slide--active' : ''}`}
        data-index={i}
        style={`--ph-gradient: ${gradientFor((img.src || '') + i)}`}
      >
        <img
          src={img.src}
          alt={img.alt || ''}
          loading={i < 2 ? 'eager' : 'lazy'}
          decoding="async"
          onerror="this.closest('.slide').classList.add('slide--missing'); this.remove();"
        />
      </div>
    ))}
  </div>

  {images.length > 1 && (
    <>
      <button class="slideshow__nav slideshow__nav--prev" aria-label="Previous image">‹</button>
      <button class="slideshow__nav slideshow__nav--next" aria-label="Next image">›</button>
      <div class="slideshow__counter" aria-live="polite">
        <span class="js-current">1</span> <span class="slideshow__sep">/</span> <span>{images.length}</span>
      </div>
    </>
  )}
</div>

<style>
  .slideshow {
    position: relative;
    width: 100%;
    height: calc(100svh - 11rem);
    min-height: 360px;
    user-select: none;
  }

  .slideshow__viewport {
    position: relative;
    width: 100%;
    height: 100%;
  }

  .slide {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.4s ease;
    pointer-events: none;
  }

  .slide--active {
    opacity: 1;
    pointer-events: auto;
  }

  .slide img {
    max-width: 100%;
    max-height: 100%;
    width: auto;
    height: auto;
    object-fit: contain;
    display: block;
  }

  .slide--missing {
    background: var(--ph-gradient, var(--paper-rise));
    aspect-ratio: 4 / 5;
    max-width: 80%;
    margin: auto;
  }

  .slideshow__nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: transparent;
    border: 0;
    cursor: pointer;
    font-size: 2.25rem;
    line-height: 1;
    color: var(--ink-faint);
    padding: 0.75rem 1rem;
    transition: color 0.2s ease;
    font-family: var(--font-body);
    z-index: 2;
  }
  .slideshow__nav:hover { color: var(--ink); }
  .slideshow__nav--prev { left: -0.5rem; }
  .slideshow__nav--next { right: -0.5rem; }

  .slideshow__counter {
    position: absolute;
    bottom: -1.75rem;
    right: 0;
    font-family: var(--font-body);
    font-size: var(--t-1);
    color: var(--ink-faint);
    letter-spacing: 0.08em;
  }
  .slideshow__sep { padding: 0 0.3rem; color: var(--rule); }

  @media (max-width: 640px) {
    .slideshow {
      height: calc(100svh - 9rem);
    }
    .slideshow__nav--prev { left: -0.25rem; }
    .slideshow__nav--next { right: -0.25rem; }
  }
</style>

<script>
  const slideshows = document.querySelectorAll('.slideshow');

  slideshows.forEach((s) => {
    const slides = s.querySelectorAll('.slide');
    if (slides.length <= 1) return;
    const counter = s.querySelector('.js-current');
    const prev = s.querySelector('.slideshow__nav--prev');
    const next = s.querySelector('.slideshow__nav--next');
    let i = 0;

    const go = (n) => {
      slides[i].classList.remove('slide--active');
      i = (n + slides.length) % slides.length;
      slides[i].classList.add('slide--active');
      if (counter) counter.textContent = String(i + 1);
    };

    prev?.addEventListener('click', () => go(i - 1));
    next?.addEventListener('click', () => go(i + 1));

    document.addEventListener('keydown', (e) => {
      if (!s.isConnected) return;
      if (e.key === 'ArrowLeft') go(i - 1);
      else if (e.key === 'ArrowRight') go(i + 1);
    });

    // Touch swipe
    let touchX = null;
    s.addEventListener('touchstart', (e) => { touchX = e.touches[0].clientX; }, { passive: true });
    s.addEventListener('touchend', (e) => {
      if (touchX == null) return;
      const dx = e.changedTouches[0].clientX - touchX;
      if (Math.abs(dx) > 40) go(dx < 0 ? i + 1 : i - 1);
      touchX = null;
    }, { passive: true });
  });
</script>
