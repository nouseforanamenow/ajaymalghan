---
import { gradientFor } from '../lib/gradients.js';
const { images } = Astro.props;
---

<div class="slideshow" data-slideshow data-total={images.length}>
  <div class="slideshow__viewport">
    {images.map((img, i) => (
      <div
        class={`slide ${i === 0 ? 'slide--active' : ''}`}
        data-index={i}
        style={`--ph-gradient: ${gradientFor((img.src || '') + i)}`}
      >
        <img
          src={img.src}
          alt={img.alt || ''}
          loading={i < 2 ? 'eager' : 'lazy'}
          decoding="async"
          onerror="this.closest('.slide').classList.add('slide--missing'); this.remove();"
        />
      </div>
    ))}
  </div>

  {images.length > 1 && (
    <>
      <button class="slideshow__zone slideshow__zone--prev" data-slideshow-prev aria-label="Previous image" tabindex="-1">
        <svg class="slideshow__chev" viewBox="0 0 32 32" width="28" height="28" aria-hidden="true">
          <path d="M21 6 L11 16 L21 26" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
      <button class="slideshow__zone slideshow__zone--next" data-slideshow-next aria-label="Next image" tabindex="-1">
        <svg class="slideshow__chev" viewBox="0 0 32 32" width="28" height="28" aria-hidden="true">
          <path d="M11 6 L21 16 L11 26" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
      <div class="slideshow__counter" aria-live="polite">
        <span class="js-current">1</span><span class="slideshow__sep">/</span><span>{images.length}</span>
      </div>
    </>
  )}
</div>

<style>
  .slideshow {
    position: relative;
    width: 100%;
    /* Fills the flex container — parent reserves space between nav, intro, and footer. */
    height: 100%;
    min-height: 320px;
    user-select: none;
  }

  .slideshow__viewport {
    position: relative;
    width: 100%;
    height: 100%;
  }

  .slide {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.4s ease;
    pointer-events: none;
  }

  .slide--active {
    opacity: 1;
    pointer-events: auto;
  }

  .slide img {
    /* additional 10% shrink so the frame sits clearly within the viewport */
    max-width: 90%;
    max-height: 90%;
    width: auto;
    height: auto;
    object-fit: contain;
    display: block;
  }

  .slide--missing {
    background: var(--ph-gradient, var(--paper-rise));
    aspect-ratio: 4 / 5;
    max-width: 60%;
    max-height: 90%;
    margin: auto;
  }

  .slideshow__counter {
    position: absolute;
    bottom: 0.5rem;
    left: 50%;
    transform: translateX(-50%);
    font-family: var(--font-body);
    font-size: var(--t-1);
    color: var(--ink-faint);
    letter-spacing: 0.08em;
    pointer-events: none;
  }
  .slideshow__sep { padding: 0 0.3rem; color: var(--rule); }

  .slideshow__zone {
    position: absolute;
    top: 0; bottom: 0;
    width: 50%;
    background: transparent;
    border: 0;
    padding: 0;
    z-index: 3;
    display: flex;
    align-items: center;
    color: var(--ink-dim);
  }
  .slideshow__zone--prev {
    left: 0;
    justify-content: flex-start;
    padding-left: clamp(0.75rem, 2vw, 1.5rem);
    cursor: url('/cursors/arrow-left.svg') 16 16, w-resize;
  }
  .slideshow__zone--next {
    right: 0;
    justify-content: flex-end;
    padding-right: clamp(0.75rem, 2vw, 1.5rem);
    cursor: url('/cursors/arrow-right.svg') 16 16, e-resize;
  }
  .slideshow__zone:focus { outline: none; }
  .slideshow__chev {
    opacity: 0.55;
    transition: opacity 0.2s ease, color 0.2s ease, transform 0.2s ease;
  }
  .slideshow__zone:hover .slideshow__chev {
    opacity: 1;
    color: var(--ink);
  }
  .slideshow__zone--prev:hover .slideshow__chev { transform: translateX(-2px); }
  .slideshow__zone--next:hover .slideshow__chev { transform: translateX(2px); }

</style>

<script>
  document.querySelectorAll('.slideshow').forEach((s) => {
    const slides = s.querySelectorAll('.slide');
    if (!slides.length) return;
    const counter = s.querySelector('.js-current');
    let i = 0;

    const go = (n) => {
      slides[i].classList.remove('slide--active');
      i = (n + slides.length) % slides.length;
      slides[i].classList.add('slide--active');
      if (counter) counter.textContent = String(i + 1);
    };

    // Controls live in the footer (data-slideshow-prev / -next). Hook at document level.
    document.querySelectorAll('[data-slideshow-prev]').forEach((btn) =>
      btn.addEventListener('click', () => go(i - 1))
    );
    document.querySelectorAll('[data-slideshow-next]').forEach((btn) =>
      btn.addEventListener('click', () => go(i + 1))
    );

    // Grid button: scroll back to series index based on URL.
    document.querySelectorAll('[data-slideshow-grid]').forEach((btn) =>
      btn.addEventListener('click', () => {
        const parts = location.pathname.split('/').filter(Boolean);
        if (parts.length >= 2) {
          // .../film/hk-alleys -> .../film
          parts.pop();
          location.href = '/' + parts.join('/');
        }
      })
    );

    document.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowLeft') go(i - 1);
      else if (e.key === 'ArrowRight') go(i + 1);
    });

    // Touch swipe on the slideshow itself
    let touchX = null;
    s.addEventListener('touchstart', (e) => { touchX = e.touches[0].clientX; }, { passive: true });
    s.addEventListener('touchend', (e) => {
      if (touchX == null) return;
      const dx = e.changedTouches[0].clientX - touchX;
      if (Math.abs(dx) > 40) go(dx < 0 ? i + 1 : i - 1);
      touchX = null;
    }, { passive: true });
  });
</script>
