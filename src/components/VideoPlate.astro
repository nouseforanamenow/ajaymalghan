---
const { video, index } = Astro.props;
const aspectRatio = video.aspectRatio || '9/16';
---

<figure class="vid">
  <div class="vid__frame" style={`aspect-ratio: ${aspectRatio};`}>
    <video
      src={video.src}
      poster={video.poster}
      controls
      playsinline
      preload={index < 1 ? 'metadata' : 'none'}
      aria-label={video.alt}
    >
      Your browser does not support the video tag. <a href={video.src}>Download the video</a>.
    </video>
  </div>
  <figcaption class="vid__caption">
    {video.title && <span class="vid__title">{video.title}</span>}
    {(video.year || video.medium) && (
      <span class="vid__meta">{[video.year, video.medium].filter(Boolean).join(' · ')}</span>
    )}
    {video.caption && <span class="vid__note">{video.caption}</span>}
  </figcaption>
</figure>

<style>
  .vid {
    display: grid; gap: 0.75rem;
    margin: clamp(2rem, 4vw, 3.5rem) auto;
    max-width: 420px;
  }
  .vid__frame {
    background: var(--paper-rise);
    overflow: hidden;
    width: 100%;
  }
  .vid__frame video {
    width: 100%; height: 100%; display: block;
    object-fit: cover;
  }
  .vid__caption {
    display: grid; gap: 0.25rem;
    padding-top: 0.25rem;
  }
  .vid__title {
    font-family: var(--font-body);
    font-size: var(--t-2);
    color: var(--ink);
  }
  .vid__meta {
    font-family: var(--font-body);
    font-size: var(--t-1);
    color: var(--ink-faint);
  }
  .vid__note {
    font-family: var(--font-body);
    font-size: var(--t-2);
    color: var(--ink-dim);
    line-height: 1.55;
    margin-top: 0.35rem;
  }
</style>
