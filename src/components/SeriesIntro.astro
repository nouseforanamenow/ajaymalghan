---
const { title, year, medium } = Astro.props;
---

<header class="series-intro">
  <h1 class="display series-intro__title">{title}</h1>
  <div class="series-intro__line">
    <span class="caption">{year}</span>
    {medium && <><span class="series-intro__sep">·</span><span class="caption">{medium}</span></>}
  </div>
</header>

<style>
  .series-intro {
    padding: clamp(2.5rem, 5vw, 4rem) 0 clamp(1.5rem, 3vw, 2.5rem);
    max-width: 64ch;
  }
  .series-intro__title {
    font-size: var(--t-6);
    font-weight: 400;
    margin-bottom: 0.75rem;
  }
  .series-intro__line {
    display: flex; gap: 0.75rem; align-items: center;
  }
  .series-intro__sep { color: var(--ink-faint); }
</style>
