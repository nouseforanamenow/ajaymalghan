<header class="nav">
  <a href="/" class="nav__brand">Ajay Malghan</a>

  <nav class="nav__primary" aria-label="Primary">
    <ul class="menu">
      <li class="menu__item menu__item--mobile-only"><a href="/">Home</a></li>
      <li class="menu__item has-sub">
        <a href="/photography">Photography</a>
        <div class="submenu">
          <div class="submenu__col">
            <a href="/photography/light" class="submenu__label">Light</a>
            <ul>
              <li><a href="/photography/light/time">Time</a></li>
              <li><a href="/photography/light/time-video">Time / Video</a></li>
              <li><a href="/photography/light/passing-through">Passing Through</a></li>
            </ul>
          </div>
          <div class="submenu__col">
            <a href="/photography/cameraless" class="submenu__label">Cameraless</a>
            <ul>
              <li><a href="/photography/cameraless/atom-city">Atom City</a></li>
              <li><a href="/photography/cameraless/urantia">Urantia</a></li>
              <li><a href="/photography/cameraless/matter">Matter</a></li>
              <li><a href="/photography/cameraless/naturally-modified">Naturally Modified</a></li>
              <li><a href="/photography/cameraless/bleached">Bleached</a></li>
            </ul>
          </div>
          <div class="submenu__col">
            <a href="/photography/film" class="submenu__label">Film</a>
            <ul>
              <li><a href="/photography/film/people-and-places">People and Places</a></li>
              <li><a href="/photography/film/vertical-density">Vertical Density</a></li>
              <li><a href="/photography/film/hk-alleys">HK Alleys</a></li>
              <li><a href="/photography/film/space-and-time">Space and Time</a></li>
              <li><a href="/photography/film/collaborations-with-nature">Collaborations With Nature</a></li>
            </ul>
          </div>
          <div class="submenu__col">
            <a href="/photography/documentary" class="submenu__label">Documentary</a>
            <ul>
              <li><a href="/photography/documentary/underground-railroad">Underground Railroad</a></li>
              <li><a href="/photography/documentary/richmond-slave-trail">Richmond Slave Trail</a></li>
            </ul>
          </div>
        </div>
      </li>
      <li class="menu__item has-sub">
        <a href="/painting">Painting</a>
        <div class="submenu submenu--single">
          <div class="submenu__col">
            <ul>
              <li><a href="/painting/12-days">12 Days</a></li>
              <li><a href="/painting/cant-remember">Can't Remember What I Was Trying to Forget</a></li>
              <li><a href="/painting/kevin">Kevin</a></li>
              <li><a href="/painting/death-is-what-you-make-of-it">Death is What You Make of It</a></li>
              <li><a href="/painting/everything-in-its-right-place">Everything in its Right Place</a></li>
            </ul>
          </div>
        </div>
      </li>
      <li class="menu__item"><a href="/music">Music</a></li>
      <li class="menu__item"><a href="/about">About</a></li>
    </ul>
  </nav>

  <button class="nav__toggle" aria-label="Open menu" aria-expanded="false">
    <span></span><span></span>
  </button>
</header>

<style>
  .nav {
    position: sticky; top: 0; z-index: 50;
    display: flex; align-items: center; justify-content: space-between;
    padding: 1.5rem var(--page-x) 1.25rem;
    background: rgba(255,255,255,0.95);
    backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--rule);
  }
  .nav__brand {
    font-family: var(--font-body);
    font-size: var(--t-3);
    color: var(--ink);
    letter-spacing: 0.01em;
  }
  .menu { display: flex; gap: clamp(1.5rem, 3vw, 2.25rem); list-style: none; }
  .menu__item > a {
    font-family: var(--font-body);
    font-size: var(--t-2);
    color: var(--ink-dim);
    padding: 0.5rem 0;
    transition: color 0.2s ease;
  }
  .menu__item > a:hover { color: var(--ink); }
  .has-sub { position: relative; }
  .submenu {
    position: absolute; top: 100%; left: 50%;
    transform: translateX(-50%) translateY(-4px);
    display: grid; grid-template-columns: repeat(4, max-content);
    gap: 2.25rem; padding: 1.5rem 1.75rem;
    background: var(--paper); border: 1px solid var(--rule);
    opacity: 0; pointer-events: none;
    transition: opacity 0.2s ease, transform 0.2s ease;
    margin-top: 0.25rem; min-width: 720px;
    box-shadow: 0 8px 30px rgba(0,0,0,0.05);
  }
  .submenu--single {
    grid-template-columns: max-content;
    min-width: 280px;
  }
  .has-sub:hover .submenu,
  .has-sub:focus-within .submenu {
    opacity: 1; pointer-events: auto; transform: translateX(-50%) translateY(0);
  }
  .submenu__label {
    display: block;
    font-family: var(--font-body);
    font-size: var(--t-1);
    color: var(--ink-faint);
    text-transform: uppercase;
    letter-spacing: 0.16em;
    margin-bottom: 0.75rem;
    transition: color 0.2s ease;
  }
  .submenu__label:hover { color: var(--ink); }
  .submenu ul { list-style: none; display: grid; gap: 0.45rem; }
  .submenu a {
    font-family: var(--font-body);
    font-size: var(--t-2);
    color: var(--ink);
    display: block;
    transition: color 0.2s ease;
    white-space: nowrap;
  }
  .submenu a:hover { color: var(--ink-dim); }
  .nav__toggle {
    display: none; background: transparent; border: 0;
    width: 32px; height: 32px; cursor: pointer;
    flex-direction: column; justify-content: center; gap: 5px;
  }
  .nav__toggle span { height: 1px; width: 22px; background: var(--ink); }
  .menu__item--mobile-only { display: none; }
  @media (max-width: 1100px) {
    .submenu { grid-template-columns: repeat(2, max-content); min-width: 460px; }
  }
  @media (max-width: 880px) {
    .nav__primary {
      position: fixed; inset: 64px 0 0 0;
      background: var(--paper); padding: 2rem var(--page-x);
      transform: translateY(-100%);
      transition: transform 0.3s ease;
      overflow-y: auto; border-bottom: 1px solid var(--rule);
    }
    .nav__primary.open { transform: translateY(0); }
    .menu { flex-direction: column; gap: 1.25rem; }
    .submenu, .submenu--single {
      position: static; transform: none; opacity: 1; pointer-events: auto;
      grid-template-columns: 1fr; gap: 1.25rem; margin-top: 0.75rem;
      padding: 1rem; min-width: 0; box-shadow: none;
    }
    .nav__toggle { display: flex; }
    .menu__item--mobile-only { display: block; }
  }
</style>

<script>
  const toggle = document.querySelector('.nav__toggle');
  const primary = document.querySelector('.nav__primary');
  toggle?.addEventListener('click', () => {
    const open = primary?.classList.toggle('open');
    toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
  });
  primary?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      primary.classList.remove('open');
      toggle?.setAttribute('aria-expanded', 'false');
    });
  });
</script>
