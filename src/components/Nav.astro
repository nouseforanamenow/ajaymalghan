---
import { getCollection } from 'astro:content';

const sortFn = (a, b) =>
  ((a.data.order ?? 999) - (b.data.order ?? 999)) ||
  ((b.data.year || '').localeCompare(a.data.year || ''));

const fetchSorted = async (name) =>
  (await getCollection(name, ({ data }) => !data.draft)).sort(sortFn);

const [light, cameraless, film, documentary, painting] = await Promise.all([
  fetchSorted('light'),
  fetchSorted('cameraless'),
  fetchSorted('film'),
  fetchSorted('documentary'),
  fetchSorted('painting'),
]);

const photoCols = [
  { slug: 'light', label: 'Light', items: light },
  { slug: 'cameraless', label: 'Cameraless', items: cameraless },
  { slug: 'film', label: 'Film', items: film },
  { slug: 'documentary', label: 'Documentary', items: documentary },
];
---

<header class="nav">
  <a href="/" class="nav__brand">Ajay Malghan</a>

  {/* DESKTOP NAV — visible on wide screens only */}
  <nav class="nav__desktop" aria-label="Primary">
    <ul class="menu">
      <li class="menu__item has-sub">
        <a href="/photography">Photography</a>
        <div class="submenu">
          {photoCols.map((col) => (
            <div class="submenu__col">
              <a href={`/photography/${col.slug}`} class="submenu__label">{col.label}</a>
              <ul>
                {col.items.map((s) => (
                  <li><a href={`/photography/${col.slug}/${s.slug}`}>{s.data.title}</a></li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </li>
      <li class="menu__item has-sub">
        <a href="/painting">Painting</a>
        <div class="submenu submenu--single">
          <div class="submenu__col">
            <ul>
              {painting.map((s) => (
                <li><a href={`/painting/${s.slug}`}>{s.data.title}</a></li>
              ))}
            </ul>
          </div>
        </div>
      </li>
      <li class="menu__item"><a href="/music">Music</a></li>
      <li class="menu__item"><a href="/about">About</a></li>
    </ul>
  </nav>

  {/* MOBILE NAV — native <details>/<summary> dropdown */}
  <details class="nav__mobile">
    <summary class="nav__mobile-summary">
      <span class="nav__mobile-summary-text">Menu</span>
      <span class="nav__mobile-summary-chev" aria-hidden="true">▾</span>
    </summary>
    <div class="nav__mobile-panel">
      <ul class="nav__mobile-list">
        <li><a href="/">Home</a></li>
        <li class="nav__mobile-section">Photography</li>
        {photoCols.map((col) => (
          <>
            <li class="nav__mobile-sub-section"><a href={`/photography/${col.slug}`}>{col.label}</a></li>
            {col.items.map((s) => (
              <li class="nav__mobile-leaf"><a href={`/photography/${col.slug}/${s.slug}`}>{s.data.title}</a></li>
            ))}
          </>
        ))}
        <li class="nav__mobile-section"><a href="/painting">Painting</a></li>
        {painting.map((s) => (
          <li class="nav__mobile-leaf"><a href={`/painting/${s.slug}`}>{s.data.title}</a></li>
        ))}
        <li class="nav__mobile-section"><a href="/music">Music</a></li>
        <li class="nav__mobile-section"><a href="/about">About</a></li>
      </ul>
    </div>
  </details>
</header>

<style>
  .nav {
    position: sticky; top: 0; z-index: 50;
    display: flex; align-items: center; justify-content: space-between;
    padding: 1.25rem var(--page-x);
    background: rgba(255,255,255,0.97);
    backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--rule);
    gap: 1rem;
  }
  .nav__brand {
    font-family: var(--font-body);
    font-size: var(--t-3);
    color: var(--ink);
    letter-spacing: 0.01em;
    flex-shrink: 0;
  }

  /* ============ DESKTOP NAV ============ */
  .nav__desktop { display: block; }
  .nav__mobile { display: none; }

  .menu { display: flex; gap: clamp(1.5rem, 3vw, 2.25rem); list-style: none; }
  .menu__item > a {
    font-family: var(--font-body);
    font-size: var(--t-2);
    color: var(--ink-dim);
    padding: 0.5rem 0;
    transition: color 0.2s ease;
  }
  .menu__item > a:hover { color: var(--ink); }
  .has-sub { position: relative; }
  .submenu {
    position: absolute; top: 100%; left: 50%;
    transform: translateX(-50%) translateY(-4px);
    display: grid; grid-template-columns: repeat(4, max-content);
    gap: 2.25rem; padding: 1.5rem 1.75rem;
    background: var(--paper); border: 1px solid var(--rule);
    opacity: 0; pointer-events: none;
    transition: opacity 0.2s ease, transform 0.2s ease;
    margin-top: 0.25rem; min-width: 720px;
    box-shadow: 0 8px 30px rgba(0,0,0,0.05);
  }
  .submenu--single {
    grid-template-columns: max-content;
    min-width: 280px;
  }
  .has-sub:hover .submenu,
  .has-sub:focus-within .submenu {
    opacity: 1; pointer-events: auto; transform: translateX(-50%) translateY(0);
  }
  .submenu__label {
    display: block;
    font-family: var(--font-body);
    font-size: var(--t-1);
    color: var(--ink-faint);
    text-transform: uppercase;
    letter-spacing: 0.16em;
    margin-bottom: 0.75rem;
    transition: color 0.2s ease;
  }
  .submenu__label:hover { color: var(--ink); }
  .submenu ul { list-style: none; display: grid; gap: 0.45rem; }
  .submenu a {
    font-family: var(--font-body);
    font-size: var(--t-2);
    color: var(--ink);
    display: block;
    transition: color 0.2s ease;
    white-space: nowrap;
  }
  .submenu a:hover { color: var(--ink-dim); }

  @media (max-width: 1100px) {
    .submenu { grid-template-columns: repeat(2, max-content); min-width: 460px; }
  }

  /* ============ MOBILE NAV ============ */
  @media (max-width: 880px) {
    .nav__desktop { display: none; }
    .nav__mobile { display: block; }
    .nav { padding: 0.9rem var(--page-x); }
  }

  .nav__mobile-summary {
    list-style: none;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.6rem 0.25rem;
    font-family: var(--font-body);
    font-size: var(--t-2);
    color: var(--ink);
    user-select: none;
    -webkit-user-select: none;
    -webkit-tap-highlight-color: rgba(0,0,0,0.08);
    touch-action: manipulation;
  }
  .nav__mobile-summary::-webkit-details-marker { display: none; }
  .nav__mobile-summary-chev {
    display: inline-block;
    font-size: 0.85em;
    transition: transform 0.2s ease;
    color: var(--ink-dim);
  }
  .nav__mobile[open] .nav__mobile-summary-chev { transform: rotate(180deg); }

  .nav__mobile-panel {
    position: absolute;
    top: 100%; left: 0; right: 0;
    background: var(--paper);
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
    max-height: calc(100svh - 60px - 3.75rem);
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
    box-shadow: 0 12px 24px rgba(0,0,0,0.06);
  }
  .nav__mobile-list {
    list-style: none;
    margin: 0;
    padding: 0.5rem var(--page-x) 1.25rem;
    display: grid;
    gap: 0.1rem;
  }
  .nav__mobile-list li { padding: 0; margin: 0; }
  .nav__mobile-list a {
    display: block;
    padding: 0.75rem 0;
    font-family: var(--font-body);
    font-size: var(--t-2);
    color: var(--ink);
    border-bottom: 1px solid transparent;
  }
  .nav__mobile-section {
    margin-top: 1rem;
    padding-top: 0.5rem;
    border-top: 1px solid var(--rule);
    font-family: var(--font-body);
    font-size: var(--t-1);
    color: var(--ink-faint);
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }
  .nav__mobile-section:first-of-type { margin-top: 0; border-top: 0; padding-top: 0; }
  .nav__mobile-section a { padding: 0.5rem 0 0; color: var(--ink); font-size: var(--t-2); text-transform: none; letter-spacing: 0; }
  .nav__mobile-sub-section {
    margin-top: 0.65rem;
    font-family: var(--font-body);
    font-size: var(--t-1);
    color: var(--ink-faint);
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }
  .nav__mobile-sub-section a {
    padding: 0.35rem 0;
    color: var(--ink-faint);
    font-size: var(--t-1);
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }
  .nav__mobile-leaf a { padding: 0.6rem 0 0.6rem 0.75rem; color: var(--ink); }
</style>

<script>
  // Close the mobile menu when any link is tapped (so navigation goes through cleanly).
  document.addEventListener('click', (e) => {
    const link = e.target.closest('.nav__mobile a');
    if (!link) return;
    const mobile = document.querySelector('.nav__mobile');
    if (mobile && mobile.hasAttribute('open')) mobile.removeAttribute('open');
  });
</script>
