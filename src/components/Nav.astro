---
import { getCollection } from 'astro:content';

const sortFn = (a, b) =>
  ((a.data.order ?? 999) - (b.data.order ?? 999)) ||
  ((b.data.year || '').localeCompare(a.data.year || ''));

const fetch = async (name) =>
  (await getCollection(name, ({ data }) => !data.draft)).sort(sortFn);

const [light, cameraless, film, documentary, painting] = await Promise.all([
  fetch('light'),
  fetch('cameraless'),
  fetch('film'),
  fetch('documentary'),
  fetch('painting'),
]);

const photoCols = [
  { slug: 'light', label: 'Light', items: light },
  { slug: 'cameraless', label: 'Cameraless', items: cameraless },
  { slug: 'film', label: 'Film', items: film },
  { slug: 'documentary', label: 'Documentary', items: documentary },
];
---

<header class="nav">
  <a href="/" class="nav__brand">Ajay Malghan</a>

  <nav class="nav__primary" aria-label="Primary">
    <ul class="menu">
      <li class="menu__item menu__item--mobile-only"><a href="/">Home</a></li>
      <li class="menu__item has-sub">
        <a href="/photography">Photography</a>
        <div class="submenu">
          {photoCols.map((col) => (
            <div class="submenu__col">
              <a href={`/photography/${col.slug}`} class="submenu__label">{col.label}</a>
              <ul>
                {col.items.map((s) => (
                  <li><a href={`/photography/${col.slug}/${s.slug}`}>{s.data.title}</a></li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </li>
      <li class="menu__item has-sub">
        <a href="/painting">Painting</a>
        <div class="submenu submenu--single">
          <div class="submenu__col">
            <ul>
              {painting.map((s) => (
                <li><a href={`/painting/${s.slug}`}>{s.data.title}</a></li>
              ))}
            </ul>
          </div>
        </div>
      </li>
      <li class="menu__item"><a href="/music">Music</a></li>
      <li class="menu__item"><a href="/about">About</a></li>
    </ul>
  </nav>

  <button class="nav__toggle" aria-label="Open menu" aria-expanded="false">
    <span class="nav__toggle-label">Menu</span>
    <span class="nav__toggle-bars">
      <span></span><span></span><span></span>
    </span>
  </button>
</header>

<style>
  .nav {
    position: sticky; top: 0; z-index: 50;
    display: flex; align-items: center; justify-content: space-between;
    padding: 1.5rem var(--page-x) 1.25rem;
    background: rgba(255,255,255,0.95);
    backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--rule);
  }
  .nav__brand {
    font-family: var(--font-body);
    font-size: var(--t-3);
    color: var(--ink);
    letter-spacing: 0.01em;
  }
  .menu { display: flex; gap: clamp(1.5rem, 3vw, 2.25rem); list-style: none; }
  .menu__item > a {
    font-family: var(--font-body);
    font-size: var(--t-2);
    color: var(--ink-dim);
    padding: 0.5rem 0;
    transition: color 0.2s ease;
  }
  .menu__item > a:hover { color: var(--ink); }
  .has-sub { position: relative; }
  .submenu {
    position: absolute; top: 100%; left: 50%;
    transform: translateX(-50%) translateY(-4px);
    display: grid; grid-template-columns: repeat(4, max-content);
    gap: 2.25rem; padding: 1.5rem 1.75rem;
    background: var(--paper); border: 1px solid var(--rule);
    opacity: 0; pointer-events: none;
    transition: opacity 0.2s ease, transform 0.2s ease;
    margin-top: 0.25rem; min-width: 720px;
    box-shadow: 0 8px 30px rgba(0,0,0,0.05);
  }
  .submenu--single {
    grid-template-columns: max-content;
    min-width: 280px;
  }
  .has-sub:hover .submenu,
  .has-sub:focus-within .submenu {
    opacity: 1; pointer-events: auto; transform: translateX(-50%) translateY(0);
  }
  .submenu__label {
    display: block;
    font-family: var(--font-body);
    font-size: var(--t-1);
    color: var(--ink-faint);
    text-transform: uppercase;
    letter-spacing: 0.16em;
    margin-bottom: 0.75rem;
    transition: color 0.2s ease;
  }
  .submenu__label:hover { color: var(--ink); }
  .submenu ul { list-style: none; display: grid; gap: 0.45rem; }
  .submenu a {
    font-family: var(--font-body);
    font-size: var(--t-2);
    color: var(--ink);
    display: block;
    transition: color 0.2s ease;
    white-space: nowrap;
  }
  .submenu a:hover { color: var(--ink-dim); }
  .nav__toggle {
    display: none; background: transparent; border: 0;
    cursor: pointer; padding: 0.75rem 0.25rem;
    align-items: center; gap: 0.6rem;
    color: var(--ink);
    font-family: var(--font-body); font-size: var(--t-2);
    -webkit-tap-highlight-color: rgba(0,0,0,0.1);
    touch-action: manipulation;
  }
  .nav__toggle * { pointer-events: none; }
  .nav__toggle-label { letter-spacing: 0.02em; }
  .nav__toggle-bars {
    display: inline-flex; flex-direction: column;
    width: 22px; gap: 5px;
  }
  .nav__toggle-bars span {
    height: 2px; width: 22px; background: var(--ink);
    border-radius: 1px; transition: transform 0.2s ease, opacity 0.2s ease;
    display: block;
  }
  .nav__toggle[aria-expanded="true"] .nav__toggle-bars span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .nav__toggle[aria-expanded="true"] .nav__toggle-bars span:nth-child(2) { opacity: 0; }
  .nav__toggle[aria-expanded="true"] .nav__toggle-bars span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }
  .menu__item--mobile-only { display: none; }
  @media (max-width: 1100px) {
    .submenu { grid-template-columns: repeat(2, max-content); min-width: 460px; }
  }
  @media (max-width: 880px) {
    /* Mobile: header is one row, hamburger always visible.
       Open menu = full-screen overlay above everything (z-index > footer). */
    .nav__primary {
      display: none;
      position: fixed;
      inset: 0;
      background: var(--paper);
      padding: 4.5rem var(--page-x) 3rem;
      overflow-y: auto;
      z-index: 100;
      -webkit-overflow-scrolling: touch;
    }
    .nav__primary.open { display: block; }
    .menu { display: flex; flex-direction: column; gap: 1.1rem; }
    .submenu, .submenu--single {
      position: static; transform: none; opacity: 1; pointer-events: auto;
      grid-template-columns: 1fr; gap: 1rem; margin-top: 0.5rem;
      padding: 0.5rem 0 0 0.75rem; min-width: 0; box-shadow: none;
      border: 0;
      display: block;
    }
    .submenu__col { margin-bottom: 0.5rem; }
    .nav__toggle {
      display: inline-flex;
      position: relative;
      z-index: 101;
    }
    .menu__item--mobile-only { display: block; }
    .nav { padding: 1rem var(--page-x); }
    /* When menu is open, lock body scroll */
    body:has(.nav__primary.open) { overflow: hidden; }
  }
</style>

<script>
  function wireNav() {
    const toggle = document.querySelector('.nav__toggle');
    const primary = document.querySelector('.nav__primary');
    if (!toggle || !primary) return;
    if (toggle.dataset.wired) return;
    toggle.dataset.wired = '1';

    const setOpen = (open) => {
      primary.classList.toggle('open', open);
      toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
      document.documentElement.style.overflow = open ? 'hidden' : '';
    };

    toggle.addEventListener('click', (e) => {
      e.preventDefault();
      e.stopPropagation();
      setOpen(!primary.classList.contains('open'));
    });

    primary.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => setOpen(false));
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') setOpen(false);
    });
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', wireNav);
  } else {
    wireNav();
  }
</script>
